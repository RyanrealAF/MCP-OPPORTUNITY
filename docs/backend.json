
{
  "entities": {
    "MCP": {
      "title": "MCP",
      "description": "A Managed Capability Provider representing an external integration or internal service.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "explicitCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "implicitCapabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "version": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "deprecated", "experimental"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "status"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A strategic objective that requires one or more MCP capabilities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "analyzing", "complete"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "Results from a combinatorial collision analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "noveltyRank": { "type": "number" }
            }
          }
        }
      },
      "required": ["timestamp", "results"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/mcps/{mcpId}": {
      "schema": { "$ref": "#/backend/entities/MCP" },
      "description": "User-specific MCP registry."
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": { "$ref": "#/backend/entities/Goal" },
      "description": "User-specific strategic goals."
    },
    "/users/{userId}/simulations/{simId}": {
      "schema": { "$ref": "#/backend/entities/Simulation" },
      "description": "Historical collision agent simulation results."
    }
  }
}
